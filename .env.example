# Copy to `.env` and adjust. All values are optional.

# Port the local backend listens on (default: 3000)
PORT=3000

# Optional shared secret. When set, the Bolna-facing endpoints
# (/api/groceries, /api/chores, /api/instructions, /api/summary,
# /api/webhook/call-ended) require this value in the Authorization header.
# Put the same value in each Bolna tool's `api_token` field.
# Leave unset for zero-config local/demo use.
# API_TOKEN=change-me-to-a-long-random-string
